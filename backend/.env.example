# Server
APP_PORT=8080
APP_ENV=development

# Database driver: "postgres" (production) or "sqlite" (zero-setup local run)
DB_DRIVER=postgres
DB_PATH=./legalpermit.db

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=legalpermit
DB_SSLMODE=disable

# Auth
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRY_HOURS=12

# File uploads
UPLOAD_DIR=./uploads

# Seed default account passwords (change after first login)
SEED_DIROPS_PASSWORD=dirops123
SEED_KADEP_PASSWORD=kadep123
